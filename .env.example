# Bitget API (read / simulated-trade permissions only — DO NOT grant live-trade)
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# Bitget Skill Hub endpoint (getagent / MCP HTTP bridge).
# If unset, technical-analysis is derived from Bitget public market data and the
# other four skills fall back to a deterministic derived signal (clearly logged
# as source="simulated"). Set this to your Skill Hub gateway to go fully live.
BITGET_SKILLHUB_URL=

# MuleRun (rationale generation). Sign up at mulerun.com, claim 2000 credits at
# credits.mule.page with code 0526BITGET. This calls MuleRun's chat completion
# endpoint — NOT OpenAI.
MULERUN_API_KEY=
MULERUN_BASE_URL=https://api.mulerun.com/v1
MULERUN_MODEL=gpt-4o-mini
