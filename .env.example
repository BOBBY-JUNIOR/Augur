# Bitget API (read / simulated-trade permissions only — DO NOT grant live-trade)
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# Bitget Skill Hub endpoint (getagent / MCP HTTP bridge).
# If unset, technical-analysis is derived from Bitget public market data and the
# other four skills fall back to a deterministic derived signal (clearly logged
# as source="simulated"). Set this to your Skill Hub gateway to go fully live.
BITGET_SKILLHUB_URL=

# ── Rationale LLM (provider-swappable) ──────────────────────────────────────
# LLM_PROVIDER selects the rationale backend: "groq" (default) or "mulerun".
# Without a key for the selected provider, rationales fall back to a deterministic
# template (logged as source="simulated").
LLM_PROVIDER=groq

# Groq (primary). Sign up at console.groq.com, create an API key.
# OpenAI-compatible endpoint; default model llama-3.3-70b-versatile.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# MuleRun (alternative — pending approval). Set LLM_PROVIDER=mulerun to use it.
# Sign up at mulerun.com, claim credits at credits.mule.page with code 0526BITGET.
MULERUN_API_KEY=
MULERUN_BASE_URL=https://api.mulerun.com/v1
MULERUN_MODEL=llama-3.3-70b-versatile
